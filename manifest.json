{
  "manifest_version": 3,
  "name": "Feedback Auto Filler",
  "version": "2.0.0",
  "description": "Injects a floating panel on the NU feedback page for one-click form filling.",
  "icons": {
    "16":  "icon16.png",
    "32":  "icon32.png",
    "48":  "icon48.png",
    "128": "icon128.png"
  },
  "permissions": [],
  "content_scripts": [
    {
      "matches": ["*://flexstudent.nu.edu.pk/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
