{
  "manifest_version": 3,
  "name": "ProFlex",
  "version": "2.0.0",
  "description": "ProFlex injects helper tools into NU portal pages for feedback filling, marks recalculation, transcript GPA projection, and theme toggling.",
  "icons": {
    "16":  "icon16.png",
    "32":  "icon32.png",
    "48":  "icon48.png",
    "128": "icon128.png"
  },
  "permissions": ["tabs"],
  "action": {
    "default_title": "ProFlex",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://flexstudent.nu.edu.pk/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
